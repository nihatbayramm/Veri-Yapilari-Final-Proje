FUNCTION hash(ip, table_size):
    h <- 5381

    FOR EACH octet IN ip:
        FOR EACH char c IN octet:
            h <- ((h << 5) + h) + ord(c)   // djb2
        END FOR
    END FOR

    RETURN h MOD table_size


FUNCTION probe(ip):
    idx <- hash(ip, TABLE_SIZE)
    start <- idx

    WHILE table[idx] IS NOT NULL:
        IF table[idx].ip == ip:
            RETURN idx

        idx <- (idx + 1) MOD TABLE_SIZE

        IF idx == start:
            RETURN -1      // tablo dolu
    END WHILE

    RETURN idx


FUNCTION check(ip):
    current_time <- now()
    idx <- probe(ip)

    IF idx == -1:
        RETURN "BLOCKED (table full)"

    entry <- table[idx]

    IF entry IS NULL OR entry.ip != ip:
        table[idx] <- {ip, 1, current_time}
        item_count <- item_count + 1
        RETURN "ALLOWED"

    IF current_time - entry.window_start > WINDOW_SIZE:
        entry.count <- 1
        entry.window_start <- current_time
        RETURN "ALLOWED"

    entry.count <- entry.count + 1

    IF entry.count > THRESHOLD:
        RETURN "BLOCKED (brute-force detected)"

    RETURN "ALLOWED"


FUNCTION stats():
    filled <- count(non-empty entries in table)

    load_factor <- (filled / TABLE_SIZE) * 100

    RETURN load_factor, filled